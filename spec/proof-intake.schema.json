{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/svy04/mimesis-engineering/spec/proof-intake.schema.json",
  "title": "Mimesis Proof Intake Record",
  "description": "Machine-readable contract for a permissioned external weak-artifact intake record.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "submitter",
    "startingArtifact",
    "artifactOwner",
    "permissionStatus",
    "publicationPreference",
    "redactionRequirements",
    "referencesStudied",
    "desiredTransformation",
    "proofBoundary",
    "safetyConfirmation",
    "prohibitedClaims"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "reviewed", "private only", "rejected"]
    },
    "submitter": {
      "type": "string",
      "minLength": 1
    },
    "startingArtifact": {
      "type": "string",
      "minLength": 1
    },
    "artifactOwner": {
      "type": "string",
      "minLength": 1
    },
    "permissionStatus": {
      "type": "string",
      "minLength": 1
    },
    "publicationPreference": {
      "type": "string",
      "enum": ["public", "anonymized", "redacted", "private only"]
    },
    "redactionRequirements": {
      "type": "string",
      "minLength": 1
    },
    "referencesStudied": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "desiredTransformation": {
      "type": "string",
      "minLength": 1
    },
    "proofBoundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "safetyConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["noSecrets", "noPrivateCustomerData", "noCopiedProtectedMaterial"],
      "properties": {
        "noSecrets": {
          "type": "boolean",
          "const": true
        },
        "noPrivateCustomerData": {
          "type": "boolean",
          "const": true
        },
        "noCopiedProtectedMaterial": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "prohibitedClaims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
