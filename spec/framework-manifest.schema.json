{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/svy04/mimesis-engineering/spec/framework-manifest.schema.json",
  "title": "Mimesis Framework Manifest",
  "description": "Machine-readable contract for the local Mimesis Engineering framework manifest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version",
    "status",
    "purpose",
    "corePhrases",
    "loop",
    "aiNativeShape",
    "entrypoints",
    "commands",
    "artifacts",
    "gates",
    "boundaries",
    "generatedFrom"
  ],
  "properties": {
    "name": {
      "type": "string",
      "const": "mimesis-engineering"
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["public-working-framework-v0.1"]
    },
    "purpose": {
      "type": "string"
    },
    "corePhrases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string"
      }
    },
    "loop": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "string"
      }
    },
    "aiNativeShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primaryUse", "humanInput", "agentOutput", "memoryRule"],
      "properties": {
        "primaryUse": {
          "type": "string"
        },
        "humanInput": {
          "type": "string"
        },
        "agentOutput": {
          "type": "string"
        },
        "memoryRule": {
          "type": "string"
        }
      }
    },
    "entrypoints": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "path", "command"],
        "properties": {
          "name": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "command": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "commands": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose"],
        "properties": {
          "name": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "purpose"],
        "properties": {
          "name": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          }
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "evidence"],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "evidence": {
            "type": "string"
          }
        }
      }
    },
    "boundaries": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "detail"],
        "properties": {
          "name": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "generatedFrom": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "string"
      }
    }
  }
}
