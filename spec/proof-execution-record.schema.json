{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/svy04/mimesis-engineering/spec/proof-execution-record.schema.json",
  "title": "Mimesis Proof Execution Record",
  "description": "Machine-readable contract for operator-supplied command evidence from a proof execution attempt. It is not proof approval, publication, adoption proof, or gate closure.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "commandEvidence",
    "safetyConfirmation",
    "boundary",
    "prohibitedClaims"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "status": {
      "type": "string",
      "enum": ["not_started", "running", "stopped", "complete_local_run"]
    },
    "artifactIntakePath": {
      "type": "string",
      "minLength": 1
    },
    "caseWorkspacePath": {
      "type": "string",
      "minLength": 1
    },
    "evidencePacketPath": {
      "type": "string",
      "minLength": 1
    },
    "claimCandidatePath": {
      "type": "string",
      "minLength": 1
    },
    "publicPreflightPath": {
      "type": "string",
      "minLength": 1
    },
    "commandEvidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "state", "exitCode"],
        "properties": {
          "command": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "enum": ["passed", "failed", "not_run", "blocked"]
          },
          "exitCode": {
            "type": "integer"
          },
          "evidencePath": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "safetyConfirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "noSecrets",
        "noPrivateCustomerData",
        "noCopiedProtectedMaterial",
        "noUnreviewedPublicationClaim"
      ],
      "properties": {
        "noSecrets": {
          "type": "boolean",
          "const": true
        },
        "noPrivateCustomerData": {
          "type": "boolean",
          "const": true
        },
        "noCopiedProtectedMaterial": {
          "type": "boolean",
          "const": true
        },
        "noUnreviewedPublicationClaim": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "boundary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "prohibitedClaims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
